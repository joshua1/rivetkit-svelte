{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": [
			"vite/client"
		],
		"paths": {
			"~/*": [
				"./src/*"
			],
			"~backend/*": [
				"./backend/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"backend/**/*.ts"
	]
}