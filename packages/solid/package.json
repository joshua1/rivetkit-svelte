{
	"name": "@blujosi/rivetkit-solid",
	"version": "2.3.3",
	"type": "module",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check-types": "tsc --noEmit"
	},
	"files": [
		"dist",
		"SKILL.md"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"solid": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./solid": {
			"types": "./dist/solid/index.d.ts",
			"solid": "./dist/solid/index.js",
			"default": "./dist/solid/index.js"
		},
		"./solidstart": {
			"types": "./dist/solidstart/index.d.ts",
			"solid": "./dist/solidstart/index.js",
			"default": "./dist/solidstart/index.js"
		}
	},
	"peerDependencies": {
		"solid-js": "^1.9.0"
	},
	"devDependencies": {
		"@rivetkit/framework-base": "^2.1.3",
		"esbuild-plugin-solid": "0.6.0",
		"solid-js": "^1.9.11",
		"tsup": "^8.5.0",
		"tsup-preset-solid": "^2.2.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"esm-env": "^1.2.2",
		"rivetkit": "^2.1.6"
	},
	"keywords": [
		"solidjs",
		"solid",
		"rivetkit",
		"rivet",
		"actors"
	]
}