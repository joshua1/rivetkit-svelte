{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"rivetkit": [
				"./node_modules/rivetkit"
			],
			"rivetkit/*": [
				"./node_modules/rivetkit/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx"
	]
}