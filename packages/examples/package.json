{
	"name": "svelte-rivetkit-example",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:web": "vite dev",
		"dev:api": "npx srvx --import tsx ./backend/index.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@blujosi/rivetkit-svelte": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.3.2",
		"npm-run-all": "^4.1.5",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@sveltejs/kit": "^2.53.4",
		"@hono/node-server": "^1.19.9",
		"@hono/node-ws": "^1.3.0",
		"hono": "4.12.3",
		"rivetkit": "^2.1.6",
		"srvx": "0.11.8",
		"vite-plugin-srvx": "1.0.2"
	}
}