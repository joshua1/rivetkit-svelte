{
	"name": "@blujosi/rivetkit-svelte",
	"version": "2.3.7",
	"scripts": {
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && cp SKILL.md dist/SKILL.md && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"SKILL.md"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/svelte/index.js",
	"types": "./dist/svelte/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./svelte": {
			"types": "./dist/svelte/index.d.ts",
			"svelte": "./dist/svelte/index.js",
			"default": "./dist/svelte/index.js"
		},
		"./sveltekit": {
			"types": "./dist/sveltekit/index.d.ts",
			"svelte": "./dist/sveltekit/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"@rivetkit/cloudflare-workers": "^2.0.0"
	},
	"peerDependenciesMeta": {
		"@rivetkit/cloudflare-workers": {
			"optional": true
		}
	},
	"devDependencies": {
		"@rivetkit/framework-base": "^2.2.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"publint": "^0.3.18",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"esm-env": "^1.2.2",
		"rivetkit": "^2.2.0"
	}
}